---
---
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ title }} - Outrun Documentation</title>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <meta name="description" content="{{ description | default: metaDescription }}">
    {% if metaAuthor %} <meta name="author" content="{{ metaAuthor }}"> {% endif %}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if env.ELEVENTY_ENV == "production" %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.getoutrun.com; style-src 'self' *.getoutrun.com https://fonts.googleapis.com; img-src 'self' *.getoutrun.com; font-src 'self' *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.getoutrun.com; frame-src 'self' *.getoutrun.com; media-src 'self' *.getoutrun.com;">
    {% endif %}
    {% if env.ELEVENTY_ENV == "development" %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.localhost *.getoutrun.com; style-src 'self' *.localhost *.getoutrun.com https://fonts.googleapis.com; img-src 'self' *.localhost *.getoutrun.com; font-src 'self' *.localhost *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.localhost *.getoutrun.com; frame-src 'self' *.localhost *.getoutrun.com; media-src 'self' *.localhost *.getoutrun.com;">
    {% endif %}
    {% comment %}
        # The `bookshop-sass` command in package.json compiles all bookshop styles
        # to this location before the Eleventy build.
        # This includes running any postcss configuration in your working directory.
    {% endcomment %}
    <link rel="stylesheet" href="/assets/tailwind.css">
    <link rel="stylesheet" href="/assets/bookshop.css">
    <link rel="stylesheet" href="/assets/css/docs.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/x-icon" href="https://cdn.getoutrun.com/website/brand/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;600&display=swap" rel="stylesheet">
    <script defer src="https://cdn.getoutrun.com/sdk/outrun.min.js"></script>
</head>
<body class="bg-dark min-h-screen font-mono">
    {% bookshop "block/menu" bind: menu %}
    
    <div class="docs-layout">


        <!-- Sidebar Navigation -->
        <nav class="docs-sidebar" id="docs-sidebar">
            <!-- Header Section -->
            <div class="docs-header">
                <h2 class="docs-title">Documentation</h2>
            </div>

            <!-- Navigation Groups -->
            <div class="docs-nav">
                <!-- Getting Started Group -->
                <div class="docs-nav-group docs-section" data-section="getting-started">
                    <button class="docs-section-toggle" aria-expanded="false">
                        <span>Getting Started</span>
                        <svg class="docs-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                    <div class="docs-subsection">
                        <a href="/docs/" class="docs-nav-link">Overview</a>
                        <a href="/docs/getting-started/" class="docs-nav-link">Quick Start</a>
                    </div>
                </div>

                <!-- Core Concepts Group -->
                <div class="docs-nav-group docs-section" data-section="concepts">
                    <button class="docs-section-toggle" aria-expanded="false">
                        <span>Core Concepts</span>
                        <svg class="docs-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                    <div class="docs-subsection">
                        <a href="/docs/concepts/" class="docs-nav-link">Overview</a>
                        <a href="/docs/concepts/objects/" class="docs-nav-link">Objects</a>
                        <a href="/docs/concepts/ingestion/" class="docs-nav-link">Ingestion</a>
                        <a href="/docs/concepts/standardization/" class="docs-nav-link">Standardization</a>
                        <a href="/docs/concepts/delivery/" class="docs-nav-link">Delivery</a>
                        <a href="/docs/concepts/storage/" class="docs-nav-link">Storage</a>
                        <a href="/docs/concepts/security/" class="docs-nav-link">Security & Compliance</a>
                    </div>
                </div>

                <!-- Sources Group -->
                <div class="docs-nav-group docs-section" data-section="sources">
                    <button class="docs-section-toggle" aria-expanded="false">
                        <span>Sources</span>
                        <svg class="docs-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                    <div class="docs-subsection">
                        <a href="/docs/sources/" class="docs-nav-link">Overview</a>
                        <a href="/docs/sources/hubspot/" class="docs-nav-link">HubSpot</a>
                        <a href="/docs/sources/salesforce/" class="docs-nav-link">Salesforce</a>
                        <a href="/docs/sources/zoho-crm/" class="docs-nav-link">Zoho CRM</a>
                        <a href="/docs/sources/confluence/" class="docs-nav-link">Confluence</a>
                        <a href="/docs/sources/google-search-console/" class="docs-nav-link">Google Search Console</a>
                    </div>
                </div>

                <!-- Destinations Group -->
                <div class="docs-nav-group docs-section" data-section="destinations">
                    <button class="docs-section-toggle" aria-expanded="false">
                        <span>Destinations</span>
                        <svg class="docs-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                    <div class="docs-subsection">
                        <a href="/docs/destinations/" class="docs-nav-link">Overview</a>
                        <a href="/docs/destinations/hubspot/" class="docs-nav-link">HubSpot</a>
                        <a href="/docs/destinations/salesforce/" class="docs-nav-link">Salesforce</a>
                        <a href="/docs/destinations/zoho-crm/" class="docs-nav-link">Zoho CRM</a>
                    </div>
                </div>

                <!-- Support Group -->
                <div class="docs-nav-group docs-section" data-section="support">
                    <button class="docs-section-toggle" aria-expanded="false">
                        <span>Support</span>
                        <svg class="docs-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </button>
                    <div class="docs-subsection">
                        <a href="/docs/support/" class="docs-nav-link">Overview</a>
                        <a href="/docs/support/faq/" class="docs-nav-link">FAQ</a>
                        <a href="/docs/support/changelog/" class="docs-nav-link">Changelog</a>
                        <a href="/docs/support/contact/" class="docs-nav-link">Contact Us</a>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Overlay for mobile -->
        <div class="docs-overlay" id="docs-overlay"></div>

        <!-- Main Content -->
        <main class="docs-main">
            <div class="docs-content-wrapper">
                <div class="docs-content">
                    <!-- Article Content -->
                    <article class="docs-article">
                        {{ content }}
                        
                        <!-- Dynamic Breadcrumbs (inserted after H1 via CSS) -->
                        {% assign path_segments = page.url | split: '/' | where_exp: "segment", "segment != ''" %}
                        {% if path_segments.size > 0 and path_segments[0] == 'docs' %}
                        <nav class="docs-breadcrumbs" aria-label="Breadcrumb">
                            <ol>
                                <!-- Home -->
                                <li><a href="/">Home</a></li>
                                <li aria-hidden="true">></li>
                                
                                <!-- Documentation -->
                                <li><a href="/docs/">Documentation</a></li>
                                <li aria-hidden="true">></li>
                                
                                <!-- Intermediate segments -->
                                {% assign current_path = '/docs' %}
                                {% for segment in path_segments offset: 1 %}
                                    {% assign current_path = current_path | append: '/' | append: segment %}
                                    {% unless forloop.last %}
                                        {% assign segment_title = segment | replace: '-', ' ' | capitalize %}
                                        {% case segment_title %}
                                            {% when 'Hubspot' %}
                                                {% assign segment_title = 'HubSpot' %}
                                            {% when 'Zoho crm' %}
                                                {% assign segment_title = 'Zoho CRM' %}
                                            {% when 'Google search console' %}
                                                {% assign segment_title = 'Google Search Console' %}
                                        {% endcase %}
                                        <li><a href="{{ current_path }}/">{{ segment_title }}</a></li>
                                        <li aria-hidden="true">></li>
                                    {% endunless %}
                                {% endfor %}
                                
                                <!-- Current page (use title from frontmatter) -->
                                <li class="current">{{ title }}</li>
                            </ol>
                        </nav>
                        {% endif %}
                    </article>
                </div>

                <!-- Desktop TOC (fixed positioned on desktop) -->
                <div class="docs-toc-desktop">
                    <div class="docs-toc-container">
                        <!-- TOC will be generated by JavaScript -->
                    </div>
                </div>
            </div>

                <!-- Pagination -->
                {% if pagination %}
                <nav class="docs-pagination">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {% if pagination.prev %}
                        <a href="{{ pagination.prev.url }}" class="prev">
                            <div class="label">Previous</div>
                            <div class="title">{{ pagination.prev.title }}</div>
                        </a>
                        {% endif %}
                        
                        {% if pagination.next %}
                        <a href="{{ pagination.next.url }}" class="next{% unless pagination.prev %} md:col-start-2{% endunless %}">
                            <div class="label">Next</div>
                            <div class="title">{{ pagination.next.title }}</div>
                        </a>
                        {% endif %}
                    </div>
                </nav>
                {% endif %}
            </div>
            
            <!-- Footer inside main content area -->
            <div class="docs-footer">
                {% bookshop "block/footer" bind: footer %}
            </div>
        </main>
    </div>

    <!-- JavaScript -->
    <script defer src="/assets/bundle.js"></script>
    <script src="/assets/js/docs.js"></script>
</body>
</html>