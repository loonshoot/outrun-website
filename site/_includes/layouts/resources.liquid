---
---
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ metaTitle | default: title }} - Outrun</title>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ metaDescription }}">
    <meta name="author" content="Outrun">
    {% if env.ELEVENTY_ENV == "production" %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.getoutrun.com; style-src 'self' *.getoutrun.com https://fonts.googleapis.com; img-src 'self' *.getoutrun.com; font-src 'self' *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.getoutrun.com; frame-src 'self' *.getoutrun.com; media-src 'self' *.getoutrun.com;">
    {% else %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.localhost *.getoutrun.com; style-src 'self' *.localhost *.getoutrun.com https://fonts.googleapis.com; img-src 'self' *.localhost *.getoutrun.com data:; font-src 'self' *.localhost *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.localhost *.getoutrun.com; frame-src 'self' *.localhost *.getoutrun.com; media-src 'self' *.localhost *.getoutrun.com;">
    {% endif %}
    <link rel="stylesheet" href="/assets/tailwind.css">
    <link rel="stylesheet" href="/assets/bookshop.css">
    <link rel="stylesheet" href="/assets/css/outrun-base.css">
    <link rel="stylesheet" href="/assets/css/resources.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/x-icon" href="https://cdn.getoutrun.com/website/brand/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;600&family=Paytone+One&display=swap" rel="stylesheet">
    <script defer src="https://cdn.getoutrun.com/sdk/outrun.min.js"></script>
</head>
<body class="bg-dark min-h-screen">
    {% bookshop "block/menu" bind: menu %}

    <main>
        <!-- Hero -->
        <section class="resources-hero relative pt-40 pb-24">
            <div class="section-grid-bg"></div>
            <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
                <div class="text-center mb-16">
                    <p class="font-mono text-sm text-pink-600 tracking-widest uppercase mb-4">Learn</p>
                    <h1 class="text-4xl lg:text-5xl font-bold text-light mb-6">Understand AI. Apply it. Build with it.</h1>
                    <div class="section-divider mx-auto mb-8"></div>
                    <div class="max-w-3xl mx-auto">
                        <p class="text-lg text-grey-500 leading-relaxed">
                            A structured learning path for business leaders and process builders. From foundational AI concepts to hands-on workflow automation.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Track Selection -->
        <section class="resources-tracks relative py-24">
            <div class="section-grid-bg"></div>
            <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
                <div class="text-center mb-12">
                    <p class="font-mono text-sm text-yellow-400 tracking-widest uppercase mb-4">Choose Your Track</p>
                    <h2 class="text-3xl lg:text-4xl font-bold text-light mb-6">Two paths. One destination.</h2>
                    <div class="section-divider section-divider--yellow mx-auto"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    {% for track_entry in learnNav.tracks %}
                    {% assign track_key = track_entry[0] %}
                    {% assign track = track_entry[1] %}
                    {% assign track_color = track.color %}
                    {% assign article_count = 0 %}
                    {% for section in track.sections %}
                        {% assign article_count = article_count | plus: section.items.size %}
                    {% endfor %}

                    <a href="/learn/{{ track.sections[0].slug }}/{{ track.sections[0].items[0].slug }}/" class="learn-track-card learn-track-card--{{ track_color }}">
                        <div class="learn-track-card-icon">
                            {% if track_key == "business-leaders" %}
                            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="0"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                            {% else %}
                            <svg width="28" height="28" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
                            {% endif %}
                        </div>
                        <h3 class="text-xl font-bold text-light mb-2">{{ track.title }}</h3>
                        <p class="text-grey-500 text-sm leading-relaxed mb-4">{{ track.description }}</p>
                        <ul class="learn-track-card-benefits">
                            {% for benefit in track.benefits %}
                            <li>
                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                {{ benefit }}
                            </li>
                            {% endfor %}
                        </ul>
                        <div class="learn-track-card-footer">
                            <span class="font-mono text-xs">{{ article_count }} articles</span>
                            <span class="learn-track-card-cta">
                                Start learning
                                <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </span>
                        </div>
                    </a>
                    {% endfor %}
                </div>
            </div>
        </section>

        <!-- The Gradient -->
        <section class="resources-tiers relative py-24">
            <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
                <div class="text-center mb-12">
                    <p class="font-mono text-sm text-cyan-400 tracking-widest uppercase mb-4">The Gradient</p>
                    <h2 class="text-3xl lg:text-4xl font-bold text-light mb-6">Three levels of depth</h2>
                    <div class="section-divider section-divider--cyan mx-auto"></div>
                </div>

                <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
                    {% for tier in learnNav.tiers %}
                    <div class="learn-tier-card">
                        <div class="learn-tier-number learn-tier-number--{{ tier.color }}">{{ tier.order }}</div>
                        <h3 class="text-lg font-bold text-light mb-2">{{ tier.title }}</h3>
                        <p class="text-grey-500 text-sm leading-relaxed">{{ tier.description }}</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </section>

        <!-- All Articles Grid -->
        <section class="resources-articles relative py-24">
            <div class="section-grid-bg"></div>
            <div class="max-w-6xl mx-auto px-6 lg:px-8 relative z-10">
                <div class="text-center mb-12">
                    <p class="font-mono text-sm text-pink-600 tracking-widest uppercase mb-4">Browse</p>
                    <h2 class="text-3xl lg:text-4xl font-bold text-light mb-6">All Articles</h2>
                    <div class="section-divider mx-auto"></div>
                </div>

                {% for track_entry in learnNav.tracks %}
                {% assign track_key = track_entry[0] %}
                {% assign track = track_entry[1] %}
                <div class="mb-16">
                    <h3 class="text-2xl font-bold text-light mb-8">
                        {% if track_key == "business-leaders" %}
                        <span class="text-yellow-400">Business Leaders</span> Track
                        {% else %}
                        <span class="text-cyan-400">Process Builders</span> Track
                        {% endif %}
                    </h3>

                    {% for section in track.sections %}
                    <div class="mb-8">
                        <p class="font-mono text-sm tracking-widest uppercase mb-4 {% if section.color == 'yellow' %}text-yellow-400{% elsif section.color == 'pink' %}text-pink-500{% else %}text-cyan-400{% endif %}">
                            {{ section.title }}
                        </p>
                        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
                            {% for item in section.items %}
                            <a href="/learn/{{ section.slug }}/{{ item.slug }}/" class="help-card group block">
                                <h4 class="text-base font-bold text-light mb-2 leading-tight group-hover:text-yellow-400 transition-colors">
                                    {{ item.title }}
                                </h4>
                                <span class="font-mono text-xs text-gray-500">{{ item.readTime }}</span>
                            </a>
                            {% endfor %}
                        </div>
                    </div>
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
        </section>
    </main>

    {% bookshop "block/footer" bind: footer %}
    <script defer src="/assets/bundle.js?v={{ bundleHash }}"></script>
</body>
</html>
