---
---
<!DOCTYPE html>
<html lang="en">
<head>
    <title>{{ metaTitle }}</title>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <meta name="description" content="{{ metaDescription }}">
    {% if metaAuthor %} <meta name="author" content="{{ metaAuthor }}"> {% endif %}
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    {% if env.ELEVENTY_ENV == "production" %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.getoutrun.com; style-src 'self' *.getoutrun.com https://fonts.googleapis.com; img-src 'self' *.getoutrun.com; font-src 'self' *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.getoutrun.com; frame-src 'self' *.getoutrun.com; media-src 'self' *.getoutrun.com;">
    {% endif %}
    {% if env.ELEVENTY_ENV == "development" %}
        <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' *.localhost *.getoutrun.com 'unsafe-inline'; style-src 'self' *.localhost *.getoutrun.com https://fonts.googleapis.com 'unsafe-inline'; img-src 'self' *.localhost *.getoutrun.com data:; font-src 'self' *.localhost *.getoutrun.com https://fonts.gstatic.com; connect-src 'self' *.localhost *.getoutrun.com http://localhost:* ws://localhost:*; frame-src 'self' *.localhost *.getoutrun.com; media-src 'self' *.localhost *.getoutrun.com;">
    {% endif %}
    {% comment %}
        # The `bookshop-sass` command in package.json compiles all bookshop styles
        # to this location before the Eleventy build.
        # This includes running any postcss configuration in your working directory.
    {% endcomment %}
    <link rel="stylesheet" href="/assets/tailwind.css">
    <link rel="stylesheet" href="/assets/bookshop.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/x-icon" href="https://cdn.getoutrun.com/website/brand/favicon.ico">
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@300;400;600&family=Paytone+One&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/outrun-base.css">
    {% if env.ELEVENTY_ENV == "production" %}
        <script defer src="https://cdn.getoutrun.com/sdk/outrun.min.js"></script>
    {% else %}
        <script defer src="/assets/js/outrun.js"></script>
    {% endif %}
</head>
<body class="bg-dark min-h-screen">
    {% bookshop "block/menu" bind: menu %}

    <!-- Zendesk Sell Notification Bar - Pinned to bottom of nav -->
    <div id="zendesk-notification" class="bg-pink-600 text-white text-center py-2 px-4 fixed top-16 left-0 w-full z-999 transition-transform duration-300 ease-in-out">
        <div class="max-w-7xl mx-auto">
            <p class="font-mono text-sm">
                ⚠️ <strong>Zendesk Sell:</strong> Customers affected by the discontinuation announcement.
                <a href="/integrations/zendesk-sell/" class="text-yellow-300 hover:text-yellow-400 underline font-bold">See migration options →</a>
            </p>
        </div>
    </div>
    <main class="gap-0 mt-16">
        {% comment %}
            # The `page` include loops through all content_blocks and renders them.
            # Using a bookshop tag here means that live previewing will catch new components.
        {% endcomment %}
        {% bookshop_include "page" content_blocks: content_blocks %}

        {% comment %}
            # Render any additional page content below the page content blocks.
        {% endcomment %}
        {{ content }}
    </main>
    {% bookshop "block/footer" bind: footer %}
    <script defer src="/assets/bundle.js?v={{ bundleHash }}"></script>
    <script defer src="/assets/js/zendesk-notification.js"></script>
</body>
</html>